{
  "name": "rental-vehicle-app",
  "private": true,
  "version": "0.0.0",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "build:win": "vite build && electron-builder --win"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@fontsource-variable/geist": "^5.2.9",
    "@hookform/resolvers": "^5.4.0",
    "@libsql/client": "^0.17.3",
    "@prisma/adapter-libsql": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "electron-updater": "^6.8.9",
    "lucide-react": "^1.17.0",
    "react": "^19.2.6",
    "react-datepicker": "^9.1.0",
    "react-day-picker": "^10.0.1",
    "react-dom": "^19.2.6",
    "react-hook-form": "^7.77.0",
    "react-router-dom": "^7.17.0",
    "recharts": "^3.8.1",
    "shadcn": "^4.10.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "xlsx": "^0.18.5",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-datepicker": "^6.2.0",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "electron": "^42.3.3",
    "electron-builder": "^26.8.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "postcss": "^8.5.15",
    "prisma": "^7.8.0",
    "tailwindcss": "^3.4.19",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "vite-plugin-electron": "^1.0.4",
    "vite-plugin-electron-renderer": "^1.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/jkrabari31/rentalvehicle"
  },
  "build": {
    "appId": "com.rentalvehicle.app",
    "productName": "Vehicle Rental System",
    "icon": "public/logo.png",
    "publish": [
      {
        "provider": "github",
        "owner": "jkrabari31",
        "repo": "rentalvehicle"
      }
    ],
    "directories": {
      "output": "release"
    },
    "files": [
      "dist",
      "dist-electron",
      "prisma-client/**/*"
    ],
    "extraResources": [
      "prisma/schema.prisma",
      {
        "from": "template.db",
        "to": "template.db"
      }
    ],
    "win": {
      "target": "nsis"
    }
  }
}
